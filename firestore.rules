rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function hasOwnUserDoc() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // Helper: caller is admin or employee
    function isAdminOrEmployee() {
      return hasOwnUserDoc() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ["admin", "employee"];
    }

    function isAdmin() {
      return hasOwnUserDoc() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function changedUserKeys() {
      return request.resource.data.diff(resource.data).changedKeys();
    }

    function selfCanUpdateUser(userId) {
      return isSelf(userId)
        && !changedUserKeys().hasAny([
          "accountApproved",
          "idVerified",
          "verificationNote",
          "verificationReasonCategory",
          "approvedAt",
          "rejectedAt",
          "approvedByAdmin",
          "reviewedByAdminUid",
          "employeePermissions",
          "addedByAdmin"
        ])
        && (!changedUserKeys().hasAny(["verificationStatus"]) || request.resource.data.verificationStatus in ["pending", "not-submitted"]);
    }

    // Generic participant helper to support multiple schema shapes.
    function isParticipant(data) {
      return isSignedIn() && data != null && (
        isAdminOrEmployee() ||
        (data.participantIds is list && request.auth.uid in data.participantIds) ||
        (data.members is list && request.auth.uid in data.members) ||
        (data.userIds is list && request.auth.uid in data.userIds) ||
        (data.clientId is string && data.clientId == request.auth.uid) ||
        (data.operatorId is string && data.operatorId == request.auth.uid) ||
        (data.uid is string && data.uid == request.auth.uid) ||
        (data.createdBy is string && data.createdBy == request.auth.uid)
      );
    }

    // ── Users ──────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Private-by-default user documents.
      allow read: if isSelf(userId);
      allow read: if isAdminOrEmployee();
      allow create, delete: if isSelf(userId) || isAdminOrEmployee();
      allow update: if isAdminOrEmployee() || selfCanUpdateUser(userId);
    }

    // ── Admin Activity (append-only audit log) ────────────────────────────
    match /adminActivity/{eventId} {
      allow read: if isAdminOrEmployee();
      allow create: if isAdminOrEmployee();
      allow update, delete: if isAdmin();
    }

    // ── Jobs ───────────────────────────────────────────────────────────────
    match /jobs/{jobId} {
      allow read:   if isParticipant(resource.data);
      allow create: if isParticipant(request.resource.data);
      allow update: if isParticipant(resource.data);
      allow delete: if isAdmin();
    }

    // ── Chats ──────────────────────────────────────────────────────────────
    match /chats/{chatId} {
      allow read:   if isParticipant(resource.data);
      allow create: if isParticipant(request.resource.data);
      allow update: if isParticipant(resource.data);
      allow delete: if isParticipant(resource.data) || isAdmin();
    }

    // ── Messages ───────────────────────────────────────────────────────────
    match /messages/{messageId} {
      allow read: if isSignedIn() && (
        isAdminOrEmployee() ||
        (resource.data.chatId is string &&
          isParticipant(get(/databases/$(database)/documents/chats/$(resource.data.chatId)).data)) ||
        (resource.data.senderId is string && resource.data.senderId == request.auth.uid)
      );
      allow create: if isSignedIn() && (
        isAdminOrEmployee() ||
        (request.resource.data.senderId is string && request.resource.data.senderId == request.auth.uid)
      ) &&
      (request.resource.data.chatId is string &&
        isParticipant(get(/databases/$(database)/documents/chats/$(request.resource.data.chatId)).data));
      allow update, delete: if isAdminOrEmployee() ||
        (resource.data.senderId is string && resource.data.senderId == request.auth.uid);
    }

    // ── Reviews ────────────────────────────────────────────────────────────
    match /reviews/{reviewId} {
      allow read: if isSignedIn() && (
        isAdminOrEmployee() ||
        request.auth.uid == resource.data.reviewerId ||
        request.auth.uid == resource.data.clientId ||
        request.auth.uid == resource.data.operatorId
      );
      allow create: if isSignedIn() && (
        isAdminOrEmployee() ||
        request.auth.uid == request.resource.data.reviewerId
      );
      allow update: if isSignedIn() &&
        (request.auth.uid == resource.data.reviewerId ||
         request.auth.uid == resource.data.clientId ||
         request.auth.uid == resource.data.operatorId ||
         isAdminOrEmployee());
      allow delete: if isSignedIn() &&
        (request.auth.uid == resource.data.reviewerId ||
         request.auth.uid == resource.data.clientId ||
         request.auth.uid == resource.data.operatorId ||
         isAdminOrEmployee());
    }

    // ── Transactions ───────────────────────────────────────────────────────
    match /transactions/{transactionId} {
      allow read:   if isParticipant(resource.data);
      allow create: if isParticipant(request.resource.data);
      allow update: if isParticipant(resource.data);
      allow delete: if isAdmin();
    }

    // ── Claims ─────────────────────────────────────────────────────────────
    match /claims/{claimId} {
      allow read: if isSignedIn() &&
        (isAdminOrEmployee() || request.auth.uid == resource.data.claimantId);
      allow create: if isSignedIn() &&
        (isAdminOrEmployee() || request.auth.uid == request.resource.data.claimantId);
      allow update: if isSignedIn() &&
        (request.auth.uid == resource.data.claimantId || isAdminOrEmployee());
      allow delete: if isAdmin();
    }

    // ── Support Chats ──────────────────────────────────────────────────────
    match /supportChats/{chatId} {
      allow read, write: if isSignedIn() &&
        (chatId == ('support_' + request.auth.uid) || isAdminOrEmployee());

      match /messages/{messageId} {
        allow read, write: if isSignedIn() &&
          (chatId == ('support_' + request.auth.uid) || isAdminOrEmployee());
      }
    }

    // ── Admin Notifications ─────────────────────────────────────────────────
    match /adminNotifications/{notifId} {
      allow create: if isSignedIn() &&
        (
          !('uid' in request.resource.data) ||
          request.resource.data.uid == null ||
          request.resource.data.uid == request.auth.uid
        );
      allow read, update: if isAdminOrEmployee();
      allow delete: if isAdmin();
    }

    // ── User Notifications (approval / rejection notices) ──────────────────
    match /notifications/{notifId} {
      // Users can read & update their own notifications; admin can read/write all
      allow read, update: if isSignedIn() &&
        (request.auth.uid == resource.data.uid || isAdminOrEmployee());
      allow create: if isAdminOrEmployee();
      allow delete: if isAdmin();
    }

    // ── Site Visits ────────────────────────────────────────────────────────
    match /siteVisits/{visitId} {
      allow create: if isSignedIn() &&
        (
          !('uid' in request.resource.data) ||
          request.resource.data.uid == null ||
          request.resource.data.uid == request.auth.uid
        );
      allow read:   if isAdminOrEmployee();
      allow delete: if isAdmin();
    }
  }
}
